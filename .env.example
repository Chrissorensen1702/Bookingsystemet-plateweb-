APP_NAME=Bookingsystem
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/bookingsystem/public
COMPANY_PROJECTS_ROOT=
TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bookingsystem
DB_USERNAME=root
DB_PASSWORD=

# Optional platform developer seed (used by PlatformUserSeeder)
PLATFORM_DEV_NAME="PlateWeb Developer"
PLATFORM_DEV_EMAIL=
PLATFORM_DEV_PASSWORD=
SEED_PLATFORM_DEV_USER=false
SEED_DEMO_DATA=false

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=true
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
# Share the session cookie across subdomains in production, e.g. ".platebook.dk".
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
# Production note: prefer SESSION_DRIVER=database, SESSION_ENCRYPT=true and SESSION_SECURE_COOKIE=true.

SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_ENABLED=true
SECURITY_HSTS_ENABLED=false
AUTH_REQUIRE_VERIFIED_EMAIL=false
# Optional dedicated host for the employee login, e.g. "login.platebook.dk".
AUTH_LOGIN_DOMAIN=
# Root domain used for tenant public booking subdomains, e.g. "platebook.dk".
PUBLIC_ROOT_DOMAIN=
# Reserved tenant subdomains that cannot be used as tenant slugs.
RESERVED_PUBLIC_SUBDOMAINS=login,www,app,api,platform
# Reserved location slugs on tenant subdomains, to avoid conflicts with app routes.
RESERVED_PUBLIC_LOCATION_SLUGS=login,platform,email,mine-vagter,ydelser,tilgaengelighed,indstillinger,profil,brugere,book-tid,up
PASSWORD_REQUIRE_UNCOMPROMISED=false
# Production note: AUTH_REQUIRE_VERIFIED_EMAIL=true, PASSWORD_REQUIRE_UNCOMPROMISED=true and SECURITY_HSTS_ENABLED=true.

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Keep local in development; set to s3-compatible disk in production.
UPLOADS_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

TWILIO_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_MESSAGING_FROM=
TWILIO_DEFAULT_COUNTRY_CODE=+45

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
